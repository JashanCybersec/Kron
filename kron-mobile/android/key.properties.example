# key.properties.example — copy to key.properties for local release builds.
# NEVER commit key.properties — it is in .gitignore.
#
# In CI, the keystore is decoded from the ANDROID_KEYSTORE_BASE64 secret
# and these values are injected via environment variables (KEY_ALIAS, etc.).

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
storeFile=keystore.jks
